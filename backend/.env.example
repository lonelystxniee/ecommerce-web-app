# Copy to .env and fill values
MONGODB_URI=mongodb://localhost:27017/ecommerce
PORT=5175
FRONTEND_URL=http://localhost:5173

# Gemini / Generative AI settings
# Your Gemini API key
# Set your Gemini / Generative API key here
GEMINI_API_KEY=
# Optional: model path (default uses text-bison)
GEMINI_MODEL=models/text-bison-001
# Optional: base URL (default uses Google's Generative Language API)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
# Optional: if using Google Cloud project-specific endpoint
GEMINI_PROJECT=
GEMINI_LOCATION=us-central1
# Optional: ObjectId to use as the sender for AI messages (admin/system user id)
AI_SENDER_ID=
