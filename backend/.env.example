# GHN configuration
GHN_API_BASE=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=your_ghn_token_here
GHN_SHOP_ID=your_shop_id_here
GHN_ENV=development

# Optional: shop origin info used when creating GHN orders from server
# (set these so server can auto-build from-address)
GHN_SHOP_DISTRICT_ID=your_shop_district_id
GHN_SHOP_WARD_CODE=your_shop_ward_code
GHN_FROM_ADDRESS=Your shop address here

# App
PORT=5175
MONGO_URI=mongodb://localhost:27017/yourdb
